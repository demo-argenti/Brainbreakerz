config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="BrainBreakerz"
run/main_scene="uid://cdiawcbxtfybt"
config/features=PackedStringArray("4.6", "Forward Plus")
boot_splash/bg_color=Color(0, 0, 0, 1)
boot_splash/show_image=false
boot_splash/stretch_mode=0
boot_splash/use_filter=false
config/icon="res://icon.svg"
boot_splash/minimum_display_time=500

[autoload]

Global="*res://scripts/global.gd"
SaveLoad="*res://scripts/SaveLoad.gd"
Transition="*res://objects/transition.tscn"
Dialogic="*res://addons/dialogic/Core/DialogicGameHandler.gd"
AudioController="*uid://cna42doxq7o8t"

[dialogic]

directories/dch_directory={}
directories/dtl_directory={
"Test Timeline": "res://Test Timeline.dtl"
}
layout/style_directory={}

[display]

window/stretch/mode="canvas_items"

[dotnet]

project/assembly_name="BrainBreakerz"

[editor_plugins]

enabled=PackedStringArray("res://addons/dialogic/plugin.cfg", "res://addons/sm_file_importer/plugin.cfg")

[gui]

theme/custom_font="uid://cybuyfk5r8ceq"

